# =============================================================================
# ExamPro - Secure Online Examination System
# Single source of truth for the whole stack (local dev + docker-compose + EC2)
# Copy to .env and fill in real values. NEVER commit .env.
# Inside docker-compose, host values become service names (see comments).
# =============================================================================

# -----------------------------------------------------------------------------
# Global
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug

# Public origin the browser uses to reach the app (Nginx edge). On EC2 set this
# to your domain or public host, e.g. https://exams.example.com. Used for CORS.
PUBLIC_ORIGIN=http://localhost
# Host port the Nginx edge publishes (docker-compose). 80 in prod, change for dev.
HTTP_PORT=80

# Shared HS256 secret used to sign AND verify every JWT across all services.
# Module 1 (auth) is the ONLY issuer; everyone else verifies with this.
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Shared service-to-service secret (sent as x-service-secret header).
# Gateway and every microservice MUST use this same value.
SERVICE_SECRET=change-me-service-secret

# Internal secret for privileged internal calls (e.g. auth -> user register).
INTERNAL_SECRET=change-me-internal-secret

# -----------------------------------------------------------------------------
# Service ports (normalized - no collisions)
# -----------------------------------------------------------------------------
GATEWAY_PORT=3000
AUTH_PORT=3001
USER_PORT=3002
EXAM_PORT=3003
STUDENT_EXAM_PORT=3004
GRADE_CHEAT_PORT=3005
LOG_PORT=3006
RISK_PORT=3007

# -----------------------------------------------------------------------------
# Internal service URLs (gateway proxy + inter-service calls)
# docker-compose: replace localhost with the service name, e.g. http://auth:3001
# -----------------------------------------------------------------------------
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
EXAM_SERVICE_URL=http://localhost:3003
STUDENT_EXAM_SERVICE_URL=http://localhost:3004
GRADE_CHEAT_SERVICE_URL=http://localhost:3005
LOG_SERVICE_URL=http://localhost:3006
RISK_SERVICE_URL=http://localhost:3007

# -----------------------------------------------------------------------------
# PostgreSQL - relational source of truth (users, auth identities, exams,
# questions, sessions, enrollments, activation codes)
# docker-compose host: postgres
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=exampro
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=exampro
# Prisma-style URL (per service can append ?schema=auth etc.)
DATABASE_URL=postgresql://exampro:change-me-postgres@localhost:5432/exampro

# -----------------------------------------------------------------------------
# MongoDB - documents + append-only (audit logs, submissions, grading results)
# docker-compose host: mongo
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_LOGS=exam_logs
MONGODB_DB_SUBMISSIONS=exam_submissions
MONGODB_DB_GRADING=exam_grading

# -----------------------------------------------------------------------------
# Redis - OTP, session cache, rate limiting, Celery broker/result, pub/sub
# docker-compose host: redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Neo4j - graph analytics (collusion rings, shared devices, multi-session)
# docker-compose host: neo4j
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-neo4j

# -----------------------------------------------------------------------------
# ChromaDB - vector store for semantic plagiarism
# ephemeral = in-memory (dev), persistent = on disk, http = chroma server
# docker-compose: use http mode against the chroma service
# -----------------------------------------------------------------------------
CHROMA_MODE=http
CHROMA_PATH=/data/chroma
CHROMA_HOST=localhost
CHROMA_PORT=8000

# -----------------------------------------------------------------------------
# Email (auth OTP via Gmail OAuth2) - leave blank to disable email in dev
# -----------------------------------------------------------------------------
GMAIL_USER=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# -----------------------------------------------------------------------------
# Grade-Cheat AI (Python service)
# -----------------------------------------------------------------------------
# Gemini - multiple keys rotate automatically on quota errors
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768
GEMINI_RATE_LIMIT_RPM=15
GEMINI_MAX_RETRIES=10
GEMINI_RETRY_WAIT_SECONDS=60
# Groq fallback (note: GROQ, not GROK)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Plagiarism scoring
CHEATING_THRESHOLD=85
SEMANTIC_WEIGHT=0.6
TFIDF_WEIGHT=0.4
