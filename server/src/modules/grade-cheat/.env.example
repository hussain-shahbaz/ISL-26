# Flask
FLASK_ENV=development
FLASK_PORT=3004
SECRET_KEY=dev-secret-key

# Gemini — multiple keys rotate automatically on 429/quota errors
# Use GEMINI_API_KEYS for several accounts, or a single GEMINI_API_KEY
GEMINI_API_KEYS=key-one,key-two,key-three
# GEMINI_API_KEY=single-key-fallback
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768
GEMINI_RETRY_WAIT_SECONDS=60
GEMINI_MAX_RETRIES=10
GEMINI_RATE_LIMIT_RPM=5

# Grok fallback (xAI) when Gemini quota fails
GROK_API_KEY=your-grok-api-key
GROK_MODEL=grok-4-1-fast-reasoning
GROK_BASE_URL=https://api.x.ai/v1
GROK_TIMEOUT=360

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=exam_grading

# Redis + Celery
REDIS_URL=redis://localhost:6379/0

# Plagiarism: 60% semantic (ChromaDB) + 40% TF-IDF
CHEATING_THRESHOLD=85
SEMANTIC_WEIGHT=0.6
TFIDF_WEIGHT=0.4

# ChromaDB (ephemeral = in-memory, persistent = disk)
CHROMA_MODE=ephemeral
CHROMA_PATH=/tmp/chroma

# Mock exam data
USE_MOCK_DATA=true
