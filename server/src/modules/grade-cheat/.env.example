# Exam Grading Service - Environment Configuration

# Flask Configuration
FLASK_ENV=development
FLASK_PORT=5000
SECRET_KEY=your-secret-key-here
DEBUG=true

# Gemini API Configuration
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=exam_grading

# Redis Configuration (NEW - for async grading and caching)
REDIS_URL=redis://localhost:6379/0

# Celery Configuration (for async task queue)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Neo4j Configuration (optional)
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jneo4j
ENABLE_NEO4J=false

# Chroma Configuration (optional)
CHROMA_MODE=ephemeral
CHROMA_PATH=/tmp/chroma
