# Flask Configuration
FLASK_ENV=development
FLASK_PORT=3004
SECRET_KEY=your-secret-key-here

# Gemini API (text questions only)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=exam_grading

# Redis + Celery
REDIS_URL=redis://localhost:6379/0

# Plagiarism threshold (0-100, TF-IDF similarity)
CHEATING_THRESHOLD=85

# Use built-in mock exam data when true
USE_MOCK_DATA=true
