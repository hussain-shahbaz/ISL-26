# grade-cheat service — standalone .env example.
# For the full stack, the repo-root .env is the single source of truth; this file
# only matters when running grade-cheat on its own (python main.py / celery).

# Flask
FLASK_ENV=development
GRADE_CHEAT_PORT=3005
SECRET_KEY=dev-secret-key

# Shared service-to-service secret (must match the gateway's SERVICE_SECRET)
SERVICE_SECRET=change-me-service-secret

# Where to pull exam + submission data (gateway-internal service URLs)
EXAM_BASE_URL=http://localhost:3003/api/exam
SUBMISSION_BASE_URL=http://localhost:3004/api/v1/student-exam

# Gemini (primary) — comma-separated keys rotate automatically on 429/quota
GEMINI_API_KEYS=key-one,key-two
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768
GEMINI_RATE_LIMIT_RPM=15
GEMINI_MAX_RETRIES=10
GEMINI_RETRY_WAIT_SECONDS=60

# Groq (fallback) — fast OpenAI-compatible inference. NOTE: GROQ (api.groq.com),
# NOT Grok/xAI (api.x.ai). The code uses the Groq endpoint.
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT=60

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=exam_grading

# Redis + Celery (broker + result backend)
REDIS_URL=redis://localhost:6379/0

# Plagiarism: 60% semantic (ChromaDB) + 40% TF-IDF
CHEATING_THRESHOLD=85
SEMANTIC_WEIGHT=0.6
TFIDF_WEIGHT=0.4

# ChromaDB: ephemeral (in-memory) | persistent (disk) | http (chroma server)
CHROMA_MODE=ephemeral
CHROMA_PATH=/tmp/chroma
CHROMA_HOST=localhost
CHROMA_PORT=8000
