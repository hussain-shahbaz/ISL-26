generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum Role {
  ADMIN
  INSTRUCTOR
  STUDENT
}
enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}
model UserProfile {
  id                String          @id
  name              String          @db.VarChar(100)
  email             String          @unique @db.VarChar(100)
  role              Role            @default(STUDENT)
  university        String?         @db.VarChar(50)
  avatarUrl         String?         @db.VarChar(500)
  bio               String?         @db.Text

  isProfileComplete Boolean         @default(false)    // ← ADD THIS
  approvalStatus    ApprovalStatus  @default(PENDING)
  approvedAt        DateTime?
  approvedBy        String?
  isDeleted         Boolean         @default(false)
  deletedAt         DateTime?
  identifier        UserIdentifier?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  @@index([email])
  @@index([role])
  @@index([university])
  @@index([approvalStatus])
  @@index([role, university])
}
model UserIdentifier {
  id            String      @id @default(uuid())
  identifier    String      @unique @db.VarChar(50)  // rollNo or employeeId
  department    String?     @db.VarChar(100)          // instructor only at registration
  degreeProgram String?     @db.VarChar(100)          // student fills later
  batch         Int?                                   // student only
  profileId     String      @unique
  profile       UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  @@index([identifier])
}